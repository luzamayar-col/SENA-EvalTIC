# ═══════════════════════════════════════════════════════════════════
# SENA EvalTIC — Plantilla de variables de entorno
# Copia este archivo como .env.local y completa los valores reales.
# ═══════════════════════════════════════════════════════════════════

# ── Base de datos (Neon Postgres via Vercel Storage) ─────────────────
# Pasos:
#   1. Vercel Dashboard → Storage → Create → Neon Postgres
#   2. Click en tu DB → pestaña ".env.local" → copiar las URLs
# Para migraciones locales usa la URL sin pooler (directa) de Neon.
DATABASE_URL="postgres://<user>:<password>@<host>-pooler.neon.tech/<dbname>?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────────────
# Genera el secret con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="<secret-aleatorio-de-64-hex-chars>"
# En producción Vercel, NEXTAUTH_URL se configura automáticamente.
# En local apunta a tu servidor de desarrollo:
NEXTAUTH_URL="http://localhost:3000"

# ── Instructor seed ───────────────────────────────────────────────────
# Datos del instructor administrador inicial.
# Se aplica ejecutando: npx prisma db seed
INSTRUCTOR_SEED_EMAIL="admin@tu-organizacion.edu.co"
INSTRUCTOR_SEED_NOMBRE="Administrador EvalTIC"
# Contraseña del primer login. Requiere: 8+ chars, mayúscula, número y carácter especial.
INSTRUCTOR_SEED_PASSWORD="<contraseña-segura: ej. Admin2025!>"

# ── Feature flag DB backend ───────────────────────────────────────────
# Mantén en "false" hasta haber ejecutado migraciones y seed en Neon.
# Cámbialo a "true" para activar el flujo completo con base de datos.
NEXT_PUBLIC_USE_DB_BACKEND="false"

# ── Cifrado de datos sensibles (API keys Resend en BD) ────────────────
# Clave AES-256 de 32 bytes (64 hex chars) para cifrar las API keys de Resend.
# Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OBLIGATORIO en producción para proteger las API keys almacenadas en la BD.
ENCRYPTION_KEY="<64-hex-chars>"

# ── Resend (correo electrónico) ───────────────────────────────────────
# Cada instructor configura su propia API key desde el panel: /instructor/perfil
# Crea una cuenta gratuita en https://resend.com (3 000 correos/mes gratis)
# La key se guarda cifrada en la BD por instructor — no se requiere variable global
